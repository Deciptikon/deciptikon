{
  "name": "editor-app",
  "version": "1.3.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "ru.deciptikon.dbeditor",
    "productName": "DBEditor",
    "artifactName": "${productName} v${version} (portable).${ext}",
    "directories": {
      "output": "../editor-app-build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*.js",
      "index.html",
      "style.css",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  }
}
